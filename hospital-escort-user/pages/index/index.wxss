/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 30rpx 30rpx 20rpx;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.role {
  display: flex;
  align-items: center;
}

.role-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.user-action {
  padding: 16rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.logout-text {
  font-size: 28rpx;
  color: #fff;
}

/* Banner轮播 */
.banner-section {
  margin: 0 30rpx 20rpx;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.gradient-1 {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.gradient-2 {
  background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
}

.banner-content {
  text-align: center;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.banner-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快捷入口 */
.quick-nav {
  background-color: #fff;
  margin: 0 30rpx 20rpx;
  padding: 40rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.gradient-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.gradient-green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.gradient-orange {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.gradient-purple {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.icon-text {
  font-size: 48rpx;
}

.nav-label {
  font-size: 26rpx;
  color: #666;
}

/* 区块 */
.section {
  margin: 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

/* 订单类型 */
.order-types {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.order-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-type-icon {
  position: relative;
  margin-bottom: 12rpx;
}

.icon {
  font-size: 56rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.order-type-label {
  font-size: 26rpx;
  color: #666;
}

/* 服务流程 */
.process-card {
  background-color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.process-step {
  display: flex;
  align-items: flex-start;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-info {
  flex: 1;
  padding-top: 8rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.process-line {
  width: 4rpx;
  height: 40rpx;
  background-color: #e8e8e8;
  margin-left: 28rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

/* 底部安全边距 */
.bottom-safe {
  height: 40rpx;
}