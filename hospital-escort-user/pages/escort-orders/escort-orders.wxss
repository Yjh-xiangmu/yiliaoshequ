/* pages/escort-orders/escort-orders.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 标签页 */
.tabs {
  background-color: #fff;
  display: flex;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #11998e;
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 30rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.status-1 {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-status.status-2 {
  background-color: #f0f9ff;
  color: #0ea5e9;
}

.order-status.status-3 {
  background-color: #f0fdf4;
  color: #22c55e;
}

/* 医院信息 */
.hospital-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hospital-name {
  display: flex;
  align-items: center;
  flex: 1;
}

.hospital-name .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hospital-name .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.department {
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
}

/* 患者信息 */
.patient-info {
  background-color: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  color: #666;
  width: 180rpx;
  flex-shrink: 0;
}

.info-row .value {
  color: #1a1a1a;
  flex: 1;
  font-weight: 500;
}

.info-row .phone {
  color: #11998e;
  text-decoration: underline;
}

/* 服务信息 */
.service-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.service-type {
  display: flex;
  align-items: center;
}

.service-type .icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.service-type .text {
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #11998e;
}

/* 特殊需求 */
.special-requirements {
  background-color: #fff9e6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #fa8c16;
}

.special-requirements .label {
  font-size: 26rpx;
  color: #fa8c16;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.special-requirements .content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
}

.action-btn.success {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}

.action-btn.secondary {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}