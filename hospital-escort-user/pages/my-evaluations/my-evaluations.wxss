/* pages/my-evaluations/my-evaluations.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx 30rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 评价卡片 */
.eval-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

/* 头部 */
.eval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.hospital-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
}

.eval-time {
  font-size: 24rpx;
  color: #999;
}

/* 评分 */
.rating-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.stars {
  display: flex;
  margin-right: 16rpx;
}

.star {
  font-size: 36rpx;
  opacity: 0.2;
}

.star.active {
  opacity: 1;
}

.rating-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fa8c16;
}

/* 标签 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 评价内容 */
.comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-style: italic;
}

/* 陪诊员信息 */
.escort-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.escort-row .label {
  color: #999;
}

.escort-row .value {
  color: #1a1a1a;
  font-weight: 500;
  margin-right: 16rpx;
}

.anonymous-tag {
  padding: 4rpx 12rpx;
  background-color: #f5f5f5;
  color: #999;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}