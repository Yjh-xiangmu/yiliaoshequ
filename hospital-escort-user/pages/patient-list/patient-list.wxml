<!--pages/patient-list/patient-list.wxml-->
<view class="page">
  <!-- 就诊人列表 -->
  <view class="patient-list">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <view 
      wx:for="{{patientList}}" 
      wx:key="id" 
      class="patient-card"
    >
      <!-- 默认标签 -->
      <view wx:if="{{item.isDefault === 1}}" class="default-tag">默认</view>

      <!-- 基本信息 -->
      <view class="patient-header">
        <view class="patient-name">{{item.name}}</view>
        <view class="patient-relation">{{item.relation}}</view>
      </view>

      <view class="patient-info">
        <view class="info-row">
          <text class="label">性别：</text>
          <text class="value">{{item.gender === 1 ? '男' : '女'}}</text>
        </view>
        <view class="info-row" wx:if="{{item.age}}">
          <text class="label">年龄：</text>
          <text class="value">{{item.age}}岁</text>
        </view>
        <view class="info-row" wx:if="{{item.phone}}">
          <text class="label">电话：</text>
          <text class="value">{{item.phone}}</text>
        </view>
        <view class="info-row" wx:if="{{item.idCard}}">
          <text class="label">身份证：</text>
          <text class="value">{{item.idCard}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="patient-actions">
        <view 
          wx:if="{{item.isDefault !== 1}}" 
          class="action-btn default-btn" 
          bindtap="setDefault" 
          data-id="{{item.id}}"
        >
          设为默认
        </view>
        <view class="action-btn edit-btn" bindtap="editPatient" data-item="{{item}}">
          编辑
        </view>
        <view 
          class="action-btn delete-btn" 
          bindtap="deletePatient" 
          data-id="{{item.id}}" 
          data-name="{{item.name}}"
        >
          删除
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && patientList.length === 0}}" class="empty">
      <text class="empty-icon">👥</text>
      <text class="empty-text">暂无就诊人，请添加</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="showAddModal">
    <text>+ 添加就诊人</text>
  </view>
</view>

<!-- 添加/编辑弹窗 - 使用page级别而非mask -->
<view wx:if="{{showModal}}" class="modal-page">
  <!-- 顶部标题栏 -->
  <view class="modal-header">
    <view class="modal-cancel" bindtap="hideModal">取消</view>
    <view class="modal-title">{{editingId ? '编辑就诊人' : '添加就诊人'}}</view>
    <view class="modal-confirm" bindtap="savePatient">保存</view>
  </view>

  <!-- 表单内容 -->
  <scroll-view scroll-y class="modal-body">
    <view class="form-item">
      <view class="form-label">姓名<text class="required">*</text></view>
      <input 
        class="form-input" 
        placeholder="请输入姓名" 
        value="{{form.name}}" 
        bindinput="onInput" 
        data-field="name"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <view class="form-label">性别</view>
      <view class="gender-group">
        <view 
          class="gender-btn {{form.gender === 1 ? 'active' : ''}}" 
          bindtap="setGender" 
          data-gender="{{1}}"
        >男</view>
        <view 
          class="gender-btn {{form.gender === 0 ? 'active' : ''}}" 
          bindtap="setGender" 
          data-gender="{{0}}"
        >女</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">年龄</view>
      <input 
        class="form-input" 
        type="number" 
        placeholder="请输入年龄" 
        value="{{form.age}}" 
        bindinput="onInput" 
        data-field="age"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <view class="form-label">手机号</view>
      <input 
        class="form-input" 
        type="number" 
        maxlength="11" 
        placeholder="请输入手机号" 
        value="{{form.phone}}" 
        bindinput="onInput" 
        data-field="phone"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <view class="form-label">身份证号</view>
      <input 
        class="form-input" 
        maxlength="18" 
        placeholder="请输入身份证号（选填）" 
        value="{{form.idCard}}" 
        bindinput="onInput" 
        data-field="idCard"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <view class="form-label">与本人关系</view>
      <picker 
        value="{{relationIndex}}" 
        range="{{relations}}" 
        bindchange="onRelationChange"
      >
        <view class="picker-value">{{relations[relationIndex]}}</view>
      </picker>
    </view>

    <!-- 底部留白，防止被键盘遮挡 -->
    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>