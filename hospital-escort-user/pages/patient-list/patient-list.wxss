/* pages/patient-list/patient-list.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 就诊人列表 */
.patient-list {
  padding: 20rpx 30rpx;
}

.patient-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}

.default-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 0 20rpx 0 20rpx;
}

.patient-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.patient-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-right: 20rpx;
}

.patient-relation {
  padding: 6rpx 16rpx;
  background-color: #f0f5ff;
  color: #667eea;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.patient-info {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}

.info-row:last-child { margin-bottom: 0; }
.info-row .label { color: #999; width: 140rpx; }
.info-row .value { color: #1a1a1a; flex: 1; }

.patient-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.default-btn {
  background-color: #f0f5ff;
  color: #667eea;
  border: 1rpx solid #667eea;
}

.edit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.delete-btn {
  background-color: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 100rpx; opacity: 0.3; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* 全屏弹窗页面（替代原来的遮罩弹窗）*/
.modal-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

/* 弹窗顶部标题栏 */
.modal-header {
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-cancel {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx 20rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.modal-confirm {
  font-size: 30rpx;
  color: #667eea;
  font-weight: 600;
  padding: 10rpx 20rpx;
}

/* 弹窗内容区 */
.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

/* 表单样式 */
.form-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required { color: #ff4d4f; margin-left: 4rpx; }

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.gender-group {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.gender-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.picker-value {
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #1a1a1a;
}