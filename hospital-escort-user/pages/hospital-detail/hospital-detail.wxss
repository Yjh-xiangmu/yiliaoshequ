/* pages/hospital-detail/hospital-detail.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

/* 医院头部 */
.hospital-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.hospital-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.hospital-level {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-item {
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-label .icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-label .text {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 1.6;
  padding-left: 40rpx;
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #667eea;
}

/* 科室选择 */
.department-grid {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.department-item {
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.department-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: #667eea;
  transform: scale(1.05);
}

/* 简介卡片 */
.intro-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 提示卡片 */
.tips-card {
  background-color: #fff9e6;
  border-radius: 20rpx;
  padding: 30rpx;
  border-left: 6rpx solid #ffc107;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 8rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.contact-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.contact-btn .icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.contact-btn .text {
  font-size: 24rpx;
  color: #666;
}

.book-btn {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}