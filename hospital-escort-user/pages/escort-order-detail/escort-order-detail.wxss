/* pages/escort-order-detail/escort-order-detail.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.content {
  padding: 20rpx 30rpx;
}

/* 状态卡片 */
.status-card {
  padding: 60rpx 30rpx;
  border-radius: 24rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.status-card.status-0 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
.status-card.status-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.status-card.status-2 { background: linear-gradient(135deg, #0284c7 0%, #06b6d4 100%); }
.status-card.status-3 { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
.status-card.status-4 { background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%); }

.status-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #11998e;
}

/* 信息卡片 */
.info-card, .price-card, .cancel-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.info-row, .price-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child, .price-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.value.special {
  color: #666;
  line-height: 1.6;
}

.value.price {
  font-size: 36rpx;
  color: #11998e;
  font-weight: bold;
}

.paid-badge {
  margin-top: 15rpx;
  padding: 12rpx 20rpx;
  background: #f0fdf4;
  color: #22c55e;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
}

/* 取消原因 */
.cancel-text {
  font-size: 28rpx;
  color: #ef4444;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  gap: 20rpx;
}

.action-group {
  display: flex;
  gap: 20rpx;
  flex: 1;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.start-btn {
  background: linear-gradient(135deg, #0284c7 0%, #06b6d4 100%);
  color: #fff;
}

.contact-btn {
  background-color: #fff;
  color: #11998e;
  border: 2rpx solid #11998e;
}

.complete-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
}