<!--pages/escort-order-detail/escort-order-detail.wxml-->
<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else class="content">
    <!-- 订单状态卡片 -->
    <view class="status-card status-{{order.status}}">
      <view class="status-icon">
        <text wx:if="{{order.status === 0}}">📋</text>
        <text wx:elif="{{order.status === 1}}">✅</text>
        <text wx:elif="{{order.status === 2}}">🚀</text>
        <text wx:elif="{{order.status === 3}}">🎉</text>
        <text wx:else>❌</text>
      </view>
      <view class="status-text">{{order.statusText}}</view>
    </view>

    <!-- 订单信息 -->
    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="info-card">
        <view class="info-row">
          <text class="label">订单号</text>
          <text class="value">{{order.orderNo}}</text>
        </view>
        <view class="info-row">
          <text class="label">就诊人</text>
          <text class="value">{{order.patientName}}</text>
        </view>
        <view class="info-row">
          <text class="label">联系电话</text>
          <text class="value">{{order.patientPhone}}</text>
        </view>
        <view class="info-row">
          <text class="label">就诊医院</text>
          <text class="value">{{order.hospitalName}}</text>
        </view>
        <view class="info-row">
          <text class="label">就诊科室</text>
          <text class="value">{{order.department}}</text>
        </view>
        <view class="info-row">
          <text class="label">预约时间</text>
          <text class="value">{{order.appointmentTime}}</text>
        </view>
        <view class="info-row">
          <text class="label">服务类型</text>
          <text class="value">{{order.serviceType}}</text>
        </view>
        <view wx:if="{{order.specialRequirements}}" class="info-row">
          <text class="label">特殊需求</text>
          <text class="value special">{{order.specialRequirements}}</text>
        </view>
      </view>
    </view>

    <!-- 费用信息 -->
    <view class="section">
      <view class="section-title">费用信息</view>
      <view class="price-card">
        <view class="price-row">
          <text class="label">服务费用</text>
          <text class="value price">¥{{order.price}}</text>
        </view>
        <view wx:if="{{order.status === 3 && order.isPaid}}" class="paid-badge">
          <text>✅ 用户已支付</text>
        </view>
      </view>
    </view>

    <!-- 取消原因 -->
    <view wx:if="{{order.status === 4 && order.cancelReason}}" class="section">
      <view class="section-title">取消原因</view>
      <view class="cancel-card">
        <text class="cancel-text">{{order.cancelReason}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏（陪诊员专用） -->
  <view wx:if="{{!loading}}" class="bottom-bar">
    <!-- 已接单：开始服务 -->
    <view wx:if="{{order.status === 1}}" class="action-btn start-btn" bindtap="startService">
      开始服务
    </view>

    <!-- 服务中：完成服务、联系患者 -->
    <view wx:if="{{order.status === 2}}" class="action-group">
      <view class="action-btn contact-btn" bindtap="contactPatient">
        联系患者
      </view>
      <view class="action-btn complete-btn" bindtap="completeService">
        完成服务
      </view>
    </view>
  </view>
</view>