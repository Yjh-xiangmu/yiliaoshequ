/* pages/order-list/order-list.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 标签页 */
.tabs {
  background-color: #fff;
  display: flex;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 30rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-status.status-0 {
  background-color: #fff9e6;
  color: #fa8c16;
}

.order-status.status-1 {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-status.status-2 {
  background-color: #f0f9ff;
  color: #0ea5e9;
}

.order-status.status-3 {
  background-color: #f0fdf4;
  color: #22c55e;
}

.order-status.status-4 {
  background-color: #fef2f2;
  color: #ef4444;
}

/* 医院信息 */
.hospital-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hospital-name {
  display: flex;
  align-items: center;
  flex: 1;
}

.hospital-name .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hospital-name .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.department {
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
}

/* 订单信息 */
.order-info {
  background-color: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  color: #666;
  width: 180rpx;
  flex-shrink: 0;
}

.info-row .value {
  color: #1a1a1a;
  flex: 1;
}

/* 陪诊员信息 */
.escort-info {
  padding: 20rpx;
  background-color: #f0f9ff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.escort-info .label {
  color: #666;
  margin-right: 16rpx;
}

.escort-info .name {
  color: #1a1a1a;
  font-weight: 600;
  margin-right: 24rpx;
}

.escort-info .phone {
  color: #1890ff;
}

/* 价格行 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.price-row .label {
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.detail {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.action-btn.cancel {
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
.action-btn.evaluate {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  color: #fff;
}