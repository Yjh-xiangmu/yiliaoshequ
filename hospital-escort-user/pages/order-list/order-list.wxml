<!--pages/order-list/order-list.wxml-->
<view class="page">
  <!-- 状态筛选Tab -->
  <view class="tabs">
    <view 
      wx:for="{{tabs}}" 
      wx:key="index"
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      {{item.name}}
      <view wx:if="{{currentTab === index}}" class="tab-indicator"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 订单卡片 -->
    <view 
      wx:for="{{orderList}}" 
      wx:key="id" 
      class="order-card"
      bindtap="goOrderDetail"
      data-id="{{item.id}}"
    >
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-no">订单号：{{item.orderNo}}</view>
        <view class="order-status status-{{item.status}}">{{item.statusText}}</view>
      </view>

      <!-- 医院信息 -->
      <view class="hospital-info">
        <view class="hospital-name">
          <text class="icon">🏥</text>
          <text class="name">{{item.hospitalName}}</text>
        </view>
        <view class="department">{{item.department}}</view>
      </view>

      <!-- 基本信息 -->
      <view class="order-info">
        <view class="info-row">
          <text class="label">就诊人：</text>
          <text class="value">{{item.patientName}}</text>
        </view>
        <view class="info-row">
          <text class="label">预约时间：</text>
          <text class="value">{{item.appointmentTime}}</text>
        </view>
        <view class="info-row">
          <text class="label">服务类型：</text>
          <text class="value">{{item.serviceType}}</text>
        </view>
      </view>

      <!-- 陪诊员信息 -->
      <view wx:if="{{item.escortName}}" class="escort-info">
        <text class="label">陪诊员：</text>
        <text class="name">{{item.escortName}}</text>
        <text class="phone">{{item.escortPhone}}</text>
      </view>

      <!-- 金额 -->
      <view class="price-row">
        <text class="label">服务费用</text>
        <text class="price">¥{{item.price}}</text>
      </view>

      <!-- 操作按钮 -->
<view class="order-actions">
  <view wx:if="{{item.status === 0}}" class="action-btn cancel" catchtap="cancelOrder" data-id="{{item.id}}" data-no="{{item.orderNo}}">
    取消订单
  </view>
  <view wx:if="{{item.status === 3 && !item.hasEvaluation}}" class="action-btn evaluate" catchtap="goEvaluate" data-id="{{item.id}}">
    评价服务
  </view>
  <view class="action-btn detail">
    查看详情
  </view>
</view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && orderList.length === 0}}" class="empty">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无订单</text>
    </view>
  </view>
</view>