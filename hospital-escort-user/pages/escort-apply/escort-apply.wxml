<!--pages/escort-apply/escort-apply.wxml-->
<view class="page">
  <!-- 如果已有申请，显示申请状态 -->
  <view wx:if="{{applyInfo}}" class="status-card status-{{applyInfo.status}}">
    <view class="status-icon">
      <text wx:if="{{applyInfo.status === 0}}">⏳</text>
      <text wx:elif="{{applyInfo.status === 1}}">✅</text>
      <text wx:else>❌</text>
    </view>
    <view class="status-title">
      <text wx:if="{{applyInfo.status === 0}}">申请审核中</text>
      <text wx:elif="{{applyInfo.status === 1}}">申请已通过</text>
      <text wx:else>申请已拒绝</text>
    </view>
    <view class="status-desc">
      <text wx:if="{{applyInfo.status === 0}}">请耐心等待，审核通常需要1-3个工作日</text>
      <text wx:elif="{{applyInfo.status === 1}}">您可以使用注册手机号和密码登录陪诊员账号</text>
      <text wx:else>拒绝原因：{{applyInfo.rejectReason}}</text>
    </view>
    <view wx:if="{{applyInfo.status === 2}}" class="reapply-btn" bindtap="reApply">
      重新申请
    </view>
  </view>

  <!-- 申请表单 -->
  <view wx:else class="form-content">
    <!-- 顶部说明 -->
    <view class="tips-card">
      <view class="tips-title">📋 申请须知</view>
      <view class="tips-content">
        <view class="tip">• 需上传真实有效的证件照片</view>
        <view class="tip">• 审核通过后即可使用手机号登录接单</view>
        <view class="tip">• 审核通常需要1-3个工作日</view>
        <view class="tip">• 请确保信息真实准确，如有虚假将被封号</view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section-title">基本信息</view>
    <view class="form-card">
      <view class="form-item">
        <view class="form-label">真实姓名<text class="required">*</text></view>
        <input class="form-input" placeholder="请输入真实姓名" value="{{form.realName}}" bindinput="onInput" data-field="realName"/>
      </view>
      <view class="form-item">
        <view class="form-label">手机号<text class="required">*</text></view>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号（作为登录账号）" value="{{form.phone}}" bindinput="onInput" data-field="phone"/>
      </view>
      <view class="form-item">
        <view class="form-label">身份证号<text class="required">*</text></view>
        <input class="form-input" maxlength="18" placeholder="请输入身份证号" value="{{form.idCardNo}}" bindinput="onInput" data-field="idCardNo"/>
      </view>
      <view class="form-item">
        <view class="form-label">设置密码<text class="required">*</text></view>
        <input class="form-input" password placeholder="请设置登录密码（至少6位）" value="{{form.password}}" bindinput="onInput" data-field="password"/>
      </view>
      <view class="form-item">
        <view class="form-label">个人简介</view>
        <textarea class="form-textarea" placeholder="介绍您的服务经验（选填）" value="{{form.intro}}" bindinput="onInput" data-field="intro" maxlength="200"/>
        <view class="textarea-count">{{form.intro.length}}/200</view>
      </view>
    </view>

    <!-- 证件上传 -->
    <view class="section-title">证件上传</view>
    <view class="form-card">
      <!-- 身份证正面 -->
      <view class="upload-item">
        <view class="upload-label">身份证正面<text class="required">*</text></view>
        <view class="upload-area" bindtap="uploadImage" data-field="idCardFront">
          <image wx:if="{{form.idCardFront}}" class="upload-preview" src="{{form.idCardFront}}" mode="aspectFill"/>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">📷</text>
            <text class="upload-text">点击上传</text>
          </view>
        </view>
      </view>

      <!-- 身份证背面 -->
      <view class="upload-item">
        <view class="upload-label">身份证背面<text class="required">*</text></view>
        <view class="upload-area" bindtap="uploadImage" data-field="idCardBack">
          <image wx:if="{{form.idCardBack}}" class="upload-preview" src="{{form.idCardBack}}" mode="aspectFill"/>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">📷</text>
            <text class="upload-text">点击上传</text>
          </view>
        </view>
      </view>

      <!-- 健康证 -->
      <view class="upload-item">
        <view class="upload-label">健康证<text class="required">*</text></view>
        <view class="upload-area" bindtap="uploadImage" data-field="healthCert">
          <image wx:if="{{form.healthCert}}" class="upload-preview" src="{{form.healthCert}}" mode="aspectFill"/>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">📋</text>
            <text class="upload-text">点击上传</text>
          </view>
        </view>
      </view>

      <!-- 陪护资格证 -->
      <view class="upload-item">
        <view class="upload-label">陪护资格证</view>
        <view class="upload-area" bindtap="uploadImage" data-field="escortCert">
          <image wx:if="{{form.escortCert}}" class="upload-preview" src="{{form.escortCert}}" mode="aspectFill"/>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">🏅</text>
            <text class="upload-text">点击上传（选填）</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="submitApply">提交申请</button>
    </view>
  </view>
</view>