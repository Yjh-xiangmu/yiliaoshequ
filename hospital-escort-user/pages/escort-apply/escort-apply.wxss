/* pages/escort-apply/escort-apply.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 状态卡片 */
.status-card {
  margin: 40rpx 30rpx;
  padding: 60rpx 30rpx;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.status-card.status-0 {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.status-card.status-1 {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.status-card.status-2 {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.status-icon { font-size: 100rpx; margin-bottom: 20rpx; }

.status-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.8;
  margin-bottom: 30rpx;
}

.reapply-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background-color: rgba(255,255,255,0.3);
  border: 2rpx solid rgba(255,255,255,0.6);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 表单内容 */
.form-content {
  padding: 20rpx 30rpx;
}

/* 提示卡片 */
.tips-card {
  background-color: #fff9e6;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #ffc107;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #667eea;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required { color: #ff4d4f; margin-left: 4rpx; }

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 上传区域 */
.upload-item {
  margin-bottom: 30rpx;
}

.upload-item:last-child { margin-bottom: 0; }

.upload-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.upload-area {
  width: 100%;
  height: 260rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx dashed #ddd;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 26rpx; color: #999; }

/* 提交按钮 */
.submit-section {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.submit-btn::after { border: none; }