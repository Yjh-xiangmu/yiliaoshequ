/* pages/escort-income/escort-income.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.total-card {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.total-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.total-amount {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
}

.income-list {
  padding: 20rpx 30rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.income-item {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.income-left {
  flex: 1;
}

.order-no {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.income-time {
  font-size: 24rpx;
  color: #999;
}

.income-right {
  text-align: right;
}

.amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #22c55e;
  margin-bottom: 8rpx;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.status.settled {
  background-color: #f0fdf4;
  color: #22c55e;
}

.status.pending {
  background-color: #fff9e6;
  color: #fa8c16;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}