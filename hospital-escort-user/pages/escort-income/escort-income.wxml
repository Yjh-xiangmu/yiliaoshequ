<!--pages/escort-income/escort-income.wxml-->
<view class="page">
  <!-- 累计收入卡片 -->
  <view class="total-card">
    <view class="total-label">累计收入</view>
    <view class="total-amount">¥{{totalIncome}}</view>
  </view>

  <!-- 收入列表 -->
  <view class="income-list">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <view 
      wx:for="{{incomeList}}" 
      wx:key="id"
      class="income-item"
    >
      <view class="income-left">
        <view class="order-no">订单号：{{item.orderNo}}</view>
        <view class="income-time">{{item.createTime}}</view>
      </view>
      <view class="income-right">
        <view class="amount">+¥{{item.amount}}</view>
        <view class="status {{item.status === 1 ? 'settled' : 'pending'}}">
          {{item.status === 1 ? '已结算' : '待结算'}}
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && incomeList.length === 0}}" class="empty">
      <text class="empty-icon">💰</text>
      <text class="empty-text">暂无收入记录</text>
    </view>
  </view>
</view>