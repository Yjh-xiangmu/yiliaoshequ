<!--pages/order-payment/order-payment.wxml-->
<view class="page">
  <!-- 支付金额 -->
  <view class="amount-card">
    <view class="amount-label">待支付金额</view>
    <view class="amount-value">
      <text class="currency">¥</text>
      <text class="number">{{payment.amount}}</text>
    </view>
    <view class="order-no">订单号：{{payment.orderNo}}</view>
  </view>

  <!-- 订单信息 -->
  <view class="info-card">
    <view class="info-title">订单信息</view>
    <view class="info-row">
      <text class="label">就诊医院</text>
      <text class="value">{{order.hospitalName}}</text>
    </view>
    <view class="info-row">
      <text class="label">就诊科室</text>
      <text class="value">{{order.department}}</text>
    </view>
    <view class="info-row">
      <text class="label">就诊人</text>
      <text class="value">{{order.patientName}}</text>
    </view>
    <view class="info-row">
      <text class="label">服务类型</text>
      <text class="value">{{order.serviceType}}</text>
    </view>
    <view class="info-row">
      <text class="label">陪诊员</text>
      <text class="value">{{order.escortName || '待分配'}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="pay-method-card">
    <view class="info-title">支付方式</view>
    <view class="method-item active">
      <view class="method-left">
        <text class="method-icon">💳</text>
        <text class="method-name">模拟支付</text>
      </view>
      <view class="method-check">✓</view>
    </view>
  </view>

  <!-- 费用明细 -->
  <view class="detail-card">
    <view class="info-title">费用明细</view>
    <view class="detail-row">
      <text class="label">服务费用</text>
      <text class="value">¥{{payment.amount}}</text>
    </view>
    <view class="detail-row">
      <text class="label">优惠减免</text>
      <text class="value discount">-¥0.00</text>
    </view>
    <view class="detail-divider"></view>
    <view class="detail-row total">
      <text class="label">实付金额</text>
      <text class="value total-value">¥{{payment.amount}}</text>
    </view>
  </view>

  <!-- 已支付状态 -->
  <view wx:if="{{isPaid}}" class="paid-card">
    <text class="paid-icon">✅</text>
    <text class="paid-text">已支付</text>
    <text class="paid-no">支付流水号：{{paymentRecord.paymentNo}}</text>
    <text class="paid-time">支付时间：{{paymentRecord.payTime}}</text>
  </view>

  <!-- 底部支付按钮 -->
  <view wx:if="{{!isPaid}}" class="bottom-bar">
    <view class="total-amount">
      实付 <text class="highlight">¥{{payment.amount}}</text>
    </view>
    <button class="pay-btn" bindtap="confirmPay" loading="{{paying}}">
      立即支付
    </button>
  </view>

  <!-- 已支付底部按钮 -->
  <view wx:else class="bottom-bar">
    <button class="done-btn" bindtap="goOrderDetail">查看订单</button>
  </view>
</view>