/* pages/escort-evaluations/escort-evaluations.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.rating-card {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  padding: 60rpx 30rpx;
  text-align: center;
}

.rating-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.rating-value {
  font-size: 96rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.rating-card .stars {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.rating-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.eval-list {
  padding: 20rpx 30rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.eval-item {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.eval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.eval-time {
  font-size: 24rpx;
  color: #999;
}

.rating-row {
  margin-bottom: 16rpx;
}

.star {
  font-size: 32rpx;
  opacity: 0.2;
}

.star.active {
  opacity: 1;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  background-color: #f9f9f9;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-style: italic;
}

.order-info {
  font-size: 24rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}