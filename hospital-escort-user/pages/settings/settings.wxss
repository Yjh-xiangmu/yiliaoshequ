/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 30rpx 30rpx 16rpx;
}

/* 菜单卡片 */
.menu-card {
  background-color: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-left {
  flex: 1;
}

.menu-label {
  font-size: 30rpx;
  color: #1a1a1a;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.logout-btn::after {
  border: none;
}

/* 全屏弹窗 */
.modal-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.modal-header {
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-cancel {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx 20rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.modal-confirm {
  font-size: 30rpx;
  color: #667eea;
  font-weight: 600;
  padding: 10rpx 20rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
}

.form-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.notify-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 0 30rpx 20rpx;
}