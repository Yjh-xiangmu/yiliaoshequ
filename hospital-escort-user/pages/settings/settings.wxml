<!--pages/settings/settings.wxml-->
<view class="page">
  <!-- 账号设置 -->
  <view class="section-title">账号设置</view>
  <view class="menu-card">
    <view class="menu-item" bindtap="editNickname">
      <view class="menu-left">
        <text class="menu-label">用户名</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{userInfo.nickname || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="editPhone">
      <view class="menu-left">
        <text class="menu-label">手机号</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{userInfo.phone || '未绑定'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 通知设置 -->
<view class="section-title">通知设置</view>
<view class="menu-card">
  <view class="menu-item">
    <view class="menu-left">
      <text class="menu-label">订单通知</text>
      <text class="menu-desc">订单状态变更时提醒</text>
    </view>
    <switch checked="{{orderNotify}}" bindchange="onOrderNotifyChange" color="#667eea"/>
  </view>
</view>

<!-- 通知说明 -->
<view class="notify-tip">💡 消息通知功能开发中，敬请期待</view>

  <!-- 关于 -->
  <view class="section-title">关于</view>
  <view class="menu-card">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-label">当前版本</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">v1.0.0</text>
      </view>
    </view>

    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-label">清除缓存</text>
      </view>
      <view class="menu-right">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>

<!-- 编辑用户名弹窗 -->
<view wx:if="{{showNicknameModal}}" class="modal-page">
  <view class="modal-header">
    <view class="modal-cancel" bindtap="hideNicknameModal">取消</view>
    <view class="modal-title">修改用户名</view>
    <view class="modal-confirm" bindtap="saveNickname">保存</view>
  </view>
  <view class="modal-body">
    <view class="form-item">
      <view class="form-label">用户名</view>
      <input 
        class="form-input"
        placeholder="请输入用户名"
        value="{{newNickname}}"
        bindinput="onNicknameInput"
        focus="{{true}}"
        maxlength="20"
      />
      <view class="input-tip">最多20个字符</view>
    </view>
  </view>
</view>

<!-- 编辑手机号弹窗 -->
<view wx:if="{{showPhoneModal}}" class="modal-page">
  <view class="modal-header">
    <view class="modal-cancel" bindtap="hidePhoneModal">取消</view>
    <view class="modal-title">修改手机号</view>
    <view class="modal-confirm" bindtap="savePhone">保存</view>
  </view>
  <view class="modal-body">
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input 
        class="form-input"
        type="number"
        placeholder="请输入手机号"
        value="{{newPhone}}"
        bindinput="onPhoneInput"
        focus="{{true}}"
        maxlength="11"
      />
    </view>
  </view>
</view>