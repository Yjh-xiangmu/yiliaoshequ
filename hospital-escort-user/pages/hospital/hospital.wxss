/* pages/hospital/hospital.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索框 */
.search-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 16rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 医院列表 */
.hospital-list {
  padding: 20rpx 30rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 医院卡片 */
.hospital-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.hospital-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.hospital-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hospital-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  flex: 1;
}

.hospital-level {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.hospital-address {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.hospital-address .icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.hospital-address .text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.hospital-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.info-item .icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-item .text {
  font-size: 26rpx;
  color: #999;
}

.hospital-departments {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.hospital-departments .label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
  margin-top: 8rpx;
}

.department-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background-color: #f0f5ff;
  color: #667eea;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.hospital-action {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}