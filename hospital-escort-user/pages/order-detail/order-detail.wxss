/* pages/order-detail/order-detail.wxss */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* 内容 */
.content {
  padding: 30rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.status-card.status-0 {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.status-card.status-1 {
  background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
}

.status-card.status-2 {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.status-card.status-3 {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.status-card.status-4 {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.status-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #667eea;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item.special {
  flex-direction: column;
  background-color: #fff9e6;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.info-item .label {
  color: #666;
  margin-bottom: 8rpx;
}

.info-item .value {
  color: #1a1a1a;
  font-weight: 500;
  text-align: right;
}

.info-item.special .value {
  text-align: left;
  line-height: 1.6;
}

/* 陪诊员卡片 */
.escort-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.escort-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.escort-info .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-right: 24rpx;
}

.escort-info .info {
  flex: 1;
}

.escort-info .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.escort-info .phone {
  font-size: 28rpx;
  color: #666;
}

.contact-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.contact-btn .icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

/* 价格卡片 */
.price-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-item .label {
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.evaluate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.cancel-btn {
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.pay-btn {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
  color: #fff;
}

.evaluate-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}